# Local Gemini Developer API mode.
# Get a key from Google AI Studio, then copy this file to .env locally.
GEMINI_API_KEY=

# Google Cloud / Gemini Enterprise Agent Platform mode.
# If GOOGLE_AGENT_PLATFORM_KEY is set, the app prefers Agent Platform mode.
# Keep this server-side only; never expose it to browser JavaScript.
# GOOGLE_AGENT_PLATFORM_KEY=
#
# Optional metadata used for deploys and diagnostics.
# GEMINI_PROJECT_NUMBER=your-project-number
#
# For Cloud Run with Application Default Credentials or service account identity,
# omit GOOGLE_AGENT_PLATFORM_KEY and set GOOGLE_CLOUD_PROJECT. The enterprise
# flag is optional in that case, but can be set to make the intended mode explicit.
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global

# Optional.
# GEMINI_MODEL=gemini-3.5-flash
# VITE_PORT=5173
# PORT=3000

# Identity-only Google sign-in. This is not Gmail/Calendar access.
# Use an OAuth 2.0 Web application client ID from Google Cloud Console.
# GOOGLE_OAUTH_CLIENT_ID=

# Signed session cookie secret. Required for production deploys.
# SESSION_SECRET=

# Optional comma-separated server-side allowlist for Google test users.
# ALLOWED_EMAILS=you@example.com,teammate@example.com

# Local Postgres defaults. scripts/local-env.sh derives DATABASE_URL and a
# worktree-specific POSTGRES_HOST_PORT when these are unset.
POSTGRES_HOST_BIND=127.0.0.1
# POSTGRES_HOST_PORT=55432
POSTGRES_DB=agent_context
POSTGRES_USER=agent_app
POSTGRES_PASSWORD=agent_app
# DATABASE_URL=postgresql://agent_app:agent_app@127.0.0.1:55432/agent_context
